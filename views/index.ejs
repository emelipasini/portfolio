    <body>
        <%- include('./partials/header'); %>

        <main id="home">
            <div class="main-page">
                <div class="presentation">
                    <h1>Emelí Pasini</h1>
                    <h2>>_ Full Stack Entwicklerin mit Backend-Schwerpunkt</h2>

                    <h3>2 Jahre Berufserfahrung + 1 Jahr Unterrichtserfahrung</h3>
                    <p>
                        Ich schreibe sauberen Code und arbeite gern im Team. Es ist mir wichtig, Wissen mit anderen zu
                        teilen. Ich lerne schnell und bringe gerne neue Ideen ins Team.
                    </p>
                    <small>Argentinisch-italienisch, wohnhaft in Bochum, Deutschland.</small>
                </div>

                <aside class="profile-picture">
                    <img
                        id="photo-image"
                        title="Foto von Emelí Pasini"
                        alt="Ein Foto von Emelí Pasini, auf dem sie lächelt und in die Kamera schaut."
                        src="/images/pfp.webp"
                    />
                </aside>
            </div>

            <div id="standards">
                <section class="standards-section">
                    <div class="standards-container">
                        <h2 class="title">Engineering-Standards</h2>
                        <p class="subtitle">Mein Bekenntnis zu wartbarem, sicherem und skalierbarem Code.</p>

                        <div class="standards-grid">
                            <div class="standard-card">
                                <h3>Architektur & Sicherheit</h3>
                                <ul>
                                    <li class="list-item">
                                        <strong class="list-title">Robust Type Safety:</strong> Volle
                                        TypeScript-Implementierung für eine fehlerfreie Codebasis und bessere
                                        Wartbarkeit.
                                    </li>
                                    <li class="list-item">
                                        <strong class="list-title">Schema-Validierung:</strong> Strikte Laufzeit-Prüfung
                                        eingehender Daten mit Zod zur Sicherung der Systemintegrität.
                                    </li>
                                    <li class="list-item">
                                        <strong class="list-title">Dokumentation:</strong> Interaktive API-Spezifikation
                                        mit Swagger als "Single Source of Truth".
                                    </li>
                                </ul>
                            </div>

                            <div class="standard-card highlight">
                                <h3>Qualitätssicherung</h3>
                                <ul>
                                    <li class="list-item">
                                        <strong class="list-title">100% Test-Abdeckung:</strong> Konsequente Unit- &
                                        Integration-Tests mit Vitest für maximale Zuverlässigkeit.
                                    </li>
                                    <li class="list-item">
                                        <strong class="list-title">Live-Metriken:</strong> Transparente Code-Qualität
                                        durch das Codecov Dashboard. <br /><a
                                            href="https://app.codecov.io/github/emelipasini/portfolio"
                                            target="_blank"
                                            rel="noreferrer"
                                            >Coverage Report ansehen ↗</a
                                        >
                                    </li>
                                    <li class="list-item">
                                        <strong class="list-title">Traceability:</strong> Strukturiertes Logging zur
                                        effizienten Fehleranalyse und Systemüberwachung.
                                    </li>
                                </ul>
                            </div>

                            <div class="standard-card">
                                <h3>Automatisierung</h3>
                                <ul>
                                    <li class="list-item">
                                        <strong class="list-title">CI/CD Pipelines:</strong> GitHub Actions, die bei
                                        jedem PR die Code-Qualität prüfen und Instabilität verhindern.
                                    </li>
                                    <li class="list-item">
                                        <strong class="list-title">Git-Governance:</strong> Einsatz von Husky und
                                        Commitlint für eine saubere und lesbare Projekthistorie.
                                    </li>
                                    <li class="list-item">
                                        <strong class="list-title">Linting & Formatting:</strong> Automatisierte
                                        Einhaltung von Best Practices zur Vermeidung technischer Schulden.
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div id="experience">
                <section>
                    <h2>Erfahrung</h2>
                    <ul>
                        <li class="list-item">
                            <p>
                                <a href="https://github.com/emelipasini/portfolio" target="_blank" rel="noreferrer"
                                    >Umzug nach Deutschland</a
                                >
                                <span class="date">
                                    <time datetime="2022-04">Okt 2023</time> - <time datetime="2023-07">heute</time>
                                </span>
                                <span class="position"> Persönliche Projekte & Weiterbildung </span>
                                <span class="description">
                                    Konzeption und Deployment meiner persönlichen Website unter Verwendung moderner
                                    Technologien zur kontinuierlichen Weiterentwicklung meiner technischen
                                    Fähigkeiten.</span
                                >
                            </p>
                        </li>
                        <li class="list-item">
                            <p>
                                <a href="https://www.geosystems.com.ar/en/" target="_blank" rel="noreferrer"
                                    >Geosystems S.A.</a
                                >
                                <span class="date">
                                    <time datetime="2022-04">Apr 2022</time> - <time datetime="2023-07">Jul 2023</time>
                                </span>
                                <span class="position"> Junior Full Stack Entwicklerin </span>
                                <span class="description">
                                    Entwicklung von APIs mit ASP.NET und Python (PostgreSQL). Verbesserung eines
                                    React-npm-Pakets. Einführung von Programmierstandards im Team.</span
                                >
                            </p>
                        </li>
                        <li class="list-item">
                            <p>
                                <a
                                    href="https://www.linkedin.com/company/ulthar-software/"
                                    target="_blank"
                                    rel="noreferrer"
                                    >Ulthar Software</a
                                >
                                <span class="date">
                                    <time datetime="2021-02">Feb 2021</time> - <time datetime="2021-08">Aug 2021</time>
                                </span>
                                <span class="position"> Junior Backend Entwicklerin </span>
                                <span class="description"
                                    >API-Entwicklung mit Node.js, Serverless, TypeScript und MongoDB. Anwendung von TDD
                                    mit Jest zur Sicherstellung der Qualität.</span
                                >
                            </p>
                        </li>
                        <li class="list-item">
                            <p>
                                <a href="https://www.digitalhouse.com/ar" target="_blank" rel="noreferrer"
                                    >Digital House</a
                                >
                                <span class="date">
                                    <time datetime="2020-02">Feb 2020</time> - <time datetime="2021-06">Jun 2021</time>
                                </span>
                                <span class="position"> Lehrassistentin im Full Stack Bootcamp </span>
                                <span class="description"
                                    >Unterstützung der Teilnehmer:innen bei Übungen und technischen Fragen im
                                    Kurs.</span
                                >
                            </p>
                        </li>
                        <li class="list-item">
                            <p class="more-info">
                                Für mehr Informationen <a href="/#contact">schreiben</a> Sie mir gern.
                            </p>
                        </li>
                    </ul>
                </section>
            </div>

            <div id="projects">
                <div>
                    <h2>Projekte</h2>
                    <section class="projects-section">
                        <article class="project">
                            <header>
                                <h4>Projekt für die Stadtregierung von Buenos Aires (CABA)</h4>
                            </header>
                            <p class="project-description">
                                Refactoring einer bestehenden API durch Verbesserung der Struktur und Codequalität.<br />
                                Erneuerung eines NPM-Pakets mit verbessertem Design und moderneren Technologien.
                            </p>
                            <footer>
                                <small>Technologien: TypeScript, Python, SCSS, React, Swagger</small>
                            </footer>
                        </article>

                        <article class="project">
                            <header>
                                <h4>Projekt für ein privates Unternehmen</h4>
                            </header>
                            <p class="project-description">
                                Entwicklung einer API zur Steuerung des unternehmensweiten Informationsflusses, die
                                durch Prozessautomatisierung die Effizienz um <strong>40 % steigerte</strong>.
                            </p>
                            <footer>
                                <small>Technologien: C#, ASP.NET, xUnit, Swagger</small>
                            </footer>
                        </article>

