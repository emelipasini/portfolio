{
    "name": "portfolio",
    "version": "3.2.0",
    "description": "",
    "main": "app.js",
    "scripts": {
        "build": "tsc",
        "start": "node --env-file=.env build/src/server.js",
        "dev": "node --watch --env-file=.env build/src/server.js",
        "check-types": "tsc --noEmit",
        "lint": "eslint src --fix",
        "prepare": "husky",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui"
    },
    "engines": {
        "npm": "11.12.1",
        "node": "24.15.0"
    },
    "keywords": [
        "typescript",
        "node",
        "express",
        "portfolio",
        "eslint",
        "husky",
        "commitlint"
    ],
    "author": "emelipasini",
    "license": "MIT",
    "devDependencies": {
        "@commitlint/cli": "20.5.3",
        "@commitlint/config-conventional": "20.5.3",
        "@eslint/js": "10.0.1",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/express": "5.0.6",
        "@types/node": "25.6.0",
        "@types/supertest": "7.2.0",
        "@types/swagger-ui-express": "4.1.8",
        "@typescript-eslint/eslint-plugin": "8.59.2",
        "@typescript-eslint/parser": "8.59.2",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "eslint": "10.3.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-n": "18.0.1",
        "eslint-plugin-promise": "7.3.0",
        "husky": "9.1.7",
        "lint-staged": "17.0.2",
        "supertest": "7.2.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.2",
        "vitest": "4.1.5"
    },
    "dependencies": {
        "ejs": "5.0.2",
        "express": "5.2.1",
        "pino": "10.3.1",
        "swagger-ui-express": "5.0.1",
        "zod": "4.4.3"
    }
}
