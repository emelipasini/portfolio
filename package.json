{
    "name": "portfolio",
    "version": "3.3.0",
    "type": "module",
    "description": "",
    "main": "app.js",
    "scripts": {
        "build": "tsc",
        "start": "node --env-file=.env build/src/server.js",
        "dev": "node --watch --env-file=.env build/src/server.js",
        "check-types": "tsc --noEmit",
        "lint": "eslint src --fix",
        "prepare": "husky",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui"
    },
    "engines": {
        "npm": "11.12.1",
        "node": "24.15.0"
    },
    "keywords": [
        "typescript",
        "node",
        "express",
        "portfolio",
        "eslint",
        "husky",
        "commitlint"
    ],
    "author": "emelipasini",
    "license": "MIT",
    "devDependencies": {
        "@commitlint/cli": "19.5.0",
        "@commitlint/config-conventional": "19.5.0",
        "@eslint/js": "9.14.0",
        "@stylistic/eslint-plugin": "2.10.1",
        "@types/express": "4.17.21",
        "@types/node": "20.17.0",
        "@types/supertest": "6.0.2",
        "@types/swagger-ui-express": "4.1.6",
        "@typescript-eslint/eslint-plugin": "8.13.0",
        "@typescript-eslint/parser": "8.13.0",
        "@vitest/coverage-v8": "4.1.6",
        "@vitest/ui": "4.1.6",
        "eslint": "^9.39.4",
        "eslint-plugin-import": "2.31.0",
        "eslint-plugin-n": "17.13.1",
        "eslint-plugin-promise": "7.1.0",
        "globals": "17.6.0",
        "husky": "9.1.6",
        "lint-staged": "15.5.2",
        "supertest": "7.0.0",
        "typescript": "5.6.3",
        "typescript-eslint": "8.13.0",
        "vitest": "4.1.6"
    },
    "dependencies": {
        "ejs": "5.0.2",
        "express": "5.2.1",
        "pino": "10.3.1",
        "swagger-ui-express": "5.0.1",
        "zod": "4.4.3"
    }
}
